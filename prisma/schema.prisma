generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  VENDOR
  MODERATOR
  ADMIN
}

enum ProjectCategory {
  KEYBOARDS
  KEYCAPS
  SWITCHES
  DESKMATS
  ARTISANS
  ACCESSORIES
}

enum ProjectStatus {
  INTEREST_CHECK
  GROUP_BUY
  PRODUCTION
  SHIPPING
  EXTRAS
  IN_STOCK
  COMPLETED
  ARCHIVED
}

enum LinkType {
  GEEKHACK
  WEBSITE
  DISCORD
  INSTAGRAM
  REDDIT
  STORE
  OTHER
}


enum ProjectHeroTextAlign {
  LEFT
  CENTER
  RIGHT
}

enum ProjectHeroSize {
  SMALL
  MEDIUM
  LARGE
  FULL
}

enum ProjectDescriptionTextAlign {
  LEFT
  CENTER
  RIGHT
}

enum ProjectDescriptionFontScale {
  SMALL
  MEDIUM
  LARGE
}

enum ProjectDescriptionMaxWidth {
  NARROW
  MEDIUM
  WIDE
  FULL
}

model KeycapProfile {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, name])
  @@map("keycap_profiles")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  displayName   String?
  bio           String?   @db.Text
  email         String?   @unique
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  role               UserRole  @default(USER)
  bannedAt           DateTime?
  banReason          String?
  forcePasswordReset Boolean   @default(false)
  lastSeenAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  accounts            Account[]
  sessions   Session[]
  vendors    Vendor[]
  projects   Project[]
  favorites  Favorite[]       @relation("UserFavorites")
  collection UserCollection[] @relation("UserCollection")
  comments   Comment[]        @relation("UserComments")
  apiKeys    ApiKey[]
  followers     Follow[]       @relation("FollowTarget")
  following     Follow[]       @relation("FollowSource")
  notifications Notification[] @relation("UserNotifications")
  notificationPreferences NotificationPreference[]
  forumThreads  ForumThread[]
  forumPosts    ForumPost[]
  buildGuides   BuildGuide[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
  vendorSuggestions VendorSuggestion[]
  reviewedVendorSuggestions VendorSuggestion[] @relation("VendorSuggestionReviewer")
  changeLogs        ProjectChangeLog[] @relation("UserChangeLogs")
  reports           ProjectReport[]    @relation("UserReports")
  resolvedReports   ProjectReport[]    @relation("ResolvedReports")
  savedFilters      SavedFilter[]      @relation("UserSavedFilters")
  imageAssets       ImageAsset[]       @relation("UserImageAssets")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model EmailVerificationToken {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

enum VendorSuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

model Vendor {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  logo          String?
  description   String?  @db.Text
  storefrontUrl String?
  verified      Boolean  @default(false)
  regionsServed String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ownerId        String?
  owner          User?            @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  projects       Project[]
  projectVendors ProjectVendor[]  @relation("VendorProjects")
  followers      Follow[]         @relation("VendorFollowers")
  suggestions    VendorSuggestion[]

  @@index([ownerId])
  @@map("vendors")
}

model VendorSuggestion {
  id              String                 @id @default(cuid())
  name            String
  normalizedName  String
  website         String?
  notes           String?                @db.Text
  status          VendorSuggestionStatus @default(PENDING)
  createdAt       DateTime               @default(now())
  reviewedAt      DateTime?

  submittedById String
  submittedBy   User @relation(fields: [submittedById], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  reviewedById String?
  reviewedBy   User? @relation("VendorSuggestionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  vendorId String?
  vendor   Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([submittedById])
  @@index([projectId])
  @@index([normalizedName])
  @@map("vendor_suggestions")
}

model Project {
  id                String          @id @default(cuid())
  title             String
  slug              String          @unique
  description       String?         @db.Text
  category          ProjectCategory
  status            ProjectStatus   @default(INTEREST_CHECK)
  priceMin          Int?
  priceMax          Int?
  currency          String          @default("USD")
  heroImage         String?
  heroTextAlign     ProjectHeroTextAlign @default(LEFT)
  heroSize          ProjectHeroSize      @default(MEDIUM)
  heroBgColor       String?
  heroTextColor     String?
  descriptionTextAlign ProjectDescriptionTextAlign @default(LEFT)
  descriptionFontScale ProjectDescriptionFontScale @default(MEDIUM)
  descriptionTextColor String?
  descriptionMaxWidth ProjectDescriptionMaxWidth   @default(MEDIUM)
  tags              String[]
  icDate            DateTime?
  gbStartDate       DateTime?
  gbEndDate         DateTime?
  estimatedDelivery String?
  featured          Boolean         @default(false)
  published         Boolean         @default(false)
  metaTitle         String?
  metaDescription   String?
  profile           String?
  shipped           Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  vendorId  String?
  vendor    Vendor?  @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  creatorId String
  creator   User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  designer       String?

  images         ProjectImage[]
  links          ProjectLink[]
  favorites      Favorite[]         @relation("ProjectFavorites")
  collection     UserCollection[]   @relation("ProjectCollection")
  projectVendors ProjectVendor[]
  comments       Comment[]
  updates        ProjectUpdate[]
  followers      Follow[]       @relation("ProjectFollowers")
  soundTests     SoundTest[]
  vendorSuggestions VendorSuggestion[]
  changeLogs     ProjectChangeLog[]
  reports        ProjectReport[]

  @@index([category])
  @@index([status])
  @@index([featured])
  @@index([published])
  @@index([createdAt])
  @@index([profile])
  @@index([shipped])
  @@map("projects")
}

model ProjectImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  order        Int      @default(0)
  linkUrl      String?
  openInNewTab Boolean  @default(true)
  createdAt    DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_images")
}

model ProjectLink {
  id    String   @id @default(cuid())
  label String
  url   String
  type  LinkType @default(OTHER)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_links")
}

model Favorite {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation("UserFavorites", fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project  @relation("ProjectFavorites", fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
  @@map("favorites")
}

model UserCollection {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation("UserCollection", fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project  @relation("ProjectCollection", fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
  @@map("user_collections")
}

model ProjectVendor {
  id        String    @id @default(cuid())
  region    String?
  storeLink String?
  endDate   DateTime?
  createdAt DateTime  @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendorId  String
  vendor    Vendor  @relation("VendorProjects", fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([projectId, vendorId, region])
  @@index([projectId])
  @@index([vendorId])
  @@map("project_vendors")
}

model Comment {
  id        String    @id @default(cuid())
  content   String    @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  userId    String
  user      User      @relation("UserComments", fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")

  @@index([projectId])
  @@index([parentId])
  @@index([userId])
  @@map("comments")
}

model ProjectUpdate {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdAt])
  @@map("project_updates")
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  key        String    @unique
  prefix     String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
  revoked    Boolean   @default(false)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([key])
  @@index([userId])
  @@map("api_keys")
}

// ─── Follow System ───────────────────────────────────────────

enum FollowTargetType {
  USER
  PROJECT
  VENDOR
  FORUM_THREAD
  FORUM_CATEGORY
}

model Follow {
  id         String           @id @default(cuid())
  targetType FollowTargetType
  targetId   String
  createdAt  DateTime         @default(now())

  userId String
  user   User @relation("FollowSource", fields: [userId], references: [id], onDelete: Cascade)

  // Optional direct relations for querying
  targetUser    User?    @relation("FollowTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  targetUserId  String?
  targetProject Project? @relation("ProjectFollowers", fields: [targetProjectId], references: [id], onDelete: Cascade)
  targetProjectId String?
  targetVendor  Vendor?  @relation("VendorFollowers", fields: [targetVendorId], references: [id], onDelete: Cascade)
  targetVendorId String?

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
  @@index([userId])
  @@map("follows")
}

// ─── Notifications ───────────────────────────────────────────

enum NotificationType {
  PROJECT_UPDATE
  PROJECT_STATUS_CHANGE
  NEW_COMMENT
  COMMENT_REPLY
  NEW_FOLLOWER
  FORUM_REPLY
  NEW_FORUM_THREAD
  GB_STARTING
  GB_ENDING
  WATCHLIST_MATCH
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  userId String
  user   User @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationPreferenceType {
  FORUM_REPLIES
  FORUM_CATEGORY_THREADS
  PROJECT_UPDATES
  PROJECT_COMMENTS
  NEW_FOLLOWERS
  WATCHLIST_MATCHES
}

model NotificationPreference {
  id        String                     @id @default(cuid())
  type      NotificationPreferenceType
  inApp     Boolean                    @default(true)
  email     Boolean                    @default(false)
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@map("notification_preferences")
}

// ─── Forums ──────────────────────────────────────────────────

model ForumCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  threads ForumThread[]

  @@map("forum_categories")
}

model ForumThread {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String   @db.Text
  pinned    Boolean  @default(false)
  locked    Boolean  @default(false)
  views     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categoryId String
  category   ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  authorId   String
  author     User          @relation(fields: [authorId], references: [id], onDelete: Cascade)

  posts ForumPost[]

  @@index([categoryId])
  @@index([authorId])
  @@index([createdAt])
  @@index([pinned])
  @@map("forum_threads")
}

model ForumPost {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  threadId String
  thread   ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId String
  author   User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentId String?
  parent   ForumPost?  @relation("ForumPostReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  ForumPost[] @relation("ForumPostReplies")

  @@index([threadId])
  @@index([authorId])
  @@index([parentId])
  @@map("forum_posts")
}

// ─── Build Guides ────────────────────────────────────────────

model BuildGuide {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  heroImage   String?
  difficulty  String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authorId String
  author   User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([published])
  @@index([createdAt])
  @@map("build_guides")
}

// ─── Sound Tests ─────────────────────────────────────────────

model SoundTest {
  id        String   @id @default(cuid())
  title     String?
  url       String
  platform  String?
  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("sound_tests")
}

// ─── Project Change Log ──────────────────────────────────────

model ProjectChangeLog {
  id        String   @id @default(cuid())
  field     String
  oldValue  String?
  newValue  String?
  summary   String
  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actorId   String
  actor     User    @relation("UserChangeLogs", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@map("project_change_logs")
}

// ─── Saved Filters / Watchlists ──────────────────────────────

model SavedFilter {
  id        String   @id @default(cuid())
  name      String
  criteria  Json     // { status?, category?, profile?, designer?, vendor?, shipped?, tags?, q? }
  notify    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User @relation("UserSavedFilters", fields: [userId], references: [id], onDelete: Cascade)

  watchlistNotifications WatchlistNotification[]

  @@index([userId])
  @@index([notify])
  @@map("saved_filters")
}

model WatchlistNotification {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())

  savedFilterId String
  savedFilter   SavedFilter @relation(fields: [savedFilterId], references: [id], onDelete: Cascade)
  projectId     String
  userId        String

  @@unique([savedFilterId, projectId, userId])
  @@index([userId, projectId])
  @@map("watchlist_notifications")
}

// ─── Reports ─────────────────────────────────────────────────

enum ReportStatus {
  OPEN
  NON_ISSUE
  RESOLVED
}

model ProjectReport {
  id        String       @id @default(cuid())
  reason    String       @db.Text
  status    ReportStatus @default(OPEN)
  createdAt DateTime     @default(now())

  resolvedAt   DateTime?
  resolvedById String?
  resolvedBy   User?   @relation("ResolvedReports", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolutionNote String?

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reporterId String
  reporter   User   @relation("UserReports", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([projectId])
  @@index([reporterId])
  @@map("project_reports")
}

model ImageAsset {
  id          String   @id @default(cuid())
  sha256      String   @unique
  url         String
  bytes       Int
  contentType String
  uploaderId  String
  uploader    User     @relation("UserImageAssets", fields: [uploaderId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([uploaderId])
  @@map("image_assets")
}
