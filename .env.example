# Database
DATABASE_URL="postgresql://keyatlas:keyatlas@localhost:5432/keyatlas?schema=public"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Discord OAuth
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Meilisearch
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="keyatlas_dev_master_key"

# Redis
REDIS_URL="redis://localhost:6379"

# Storage
STORAGE_PROVIDER="local"
UPLOAD_DIR="public/uploads"

# Email (SMTP)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Notification email provider
MAIL_PROVIDER="mailgun"
MAILGUN_API_KEY=""
MAILGUN_DOMAIN=""
MAIL_FROM=""
APP_URL="http://localhost:3000"

# Cloudflare Turnstile (anti-bot verification on signup)
# Get keys from https://dash.cloudflare.com/ → Turnstile
TURNSTILE_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# Feature flags
# Set to "true" to require admin review before projects are published
REQUIRE_PROJECT_REVIEW="false"

# Cloudflare Images (set STORAGE_PROVIDER=cloudflare to enable)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_HASH=
